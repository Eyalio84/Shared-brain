#!/usr/bin/env bash
# todo-done — flip the first matching unchecked task to checked with today's date.
#
# Usage:
#   scripts/todo-done "<partial task text>"
#
# Example:
#   scripts/todo-done "Implement TODO.md parser"
#
# Behavior:
#   - Match is case-insensitive substring against the task title.
#   - "- [ ] (P1, @owner) ..." becomes "- [x] (P1, @owner, YYYY-MM-DD) ..."
#   - If multiple tasks match, only the first is flipped (report the rest).
#   - Existing completion date (if any) is left in place; today's date appended only if absent.

set -euo pipefail
cd "$(dirname "$0")/.."

die() { echo "todo-done: $1" >&2; exit 2; }

[ "$#" -eq 1 ] || { echo "usage: $0 \"<partial task text>\"" >&2; exit 2; }
QUERY="$1"
TODAY="$(date +%Y-%m-%d)"
TODO_FILE="TODO.md"
[ -f "$TODO_FILE" ] || die "TODO.md not found in $(pwd)"

# Find unchecked lines containing the query (case-insensitive substring).
# Using awk because bracket handling across bash double-quotes + grep BRE is fragile.
mapfile -t HITS < <(awk -v q="$QUERY" '
  BEGIN { ql = tolower(q) }
  /^- \[ \]/ { if (index(tolower($0), ql)) print NR ":" $0 }
' "$TODO_FILE")

if [ "${#HITS[@]}" -eq 0 ]; then
  die "no unchecked task matching: $QUERY"
fi

MATCH_LINE="${HITS[0]%%:*}"
ORIGINAL="${HITS[0]#*:}"

# Build the flipped line: swap [ ] → [x], append date into the parens if absent.
# Use sed for the brackets — bash ${var/pat/repl} treats `[ ]` as a glob char class.
FLIPPED="$(printf '%s\n' "$ORIGINAL" | sed 's/- \[ \]/- [x]/')"
if ! printf '%s' "$FLIPPED" | grep -qE '[0-9]{4}-[0-9]{2}-[0-9]{2}'; then
  # Insert ", YYYY-MM-DD" before the closing paren of the first parens group.
  FLIPPED="$(printf '%s\n' "$FLIPPED" | sed -E "0,/\)/{s/\)/, ${TODAY})/}")"
fi

# Rewrite the file with the change at the exact line.
awk -v target="$MATCH_LINE" -v replacement="$FLIPPED" '
  NR == target { print replacement; next }
  { print }
' "$TODO_FILE" > "${TODO_FILE}.tmp" && mv "${TODO_FILE}.tmp" "$TODO_FILE"

echo "done: $FLIPPED"

if [ "${#HITS[@]}" -gt 1 ]; then
  echo "note: ${#HITS[@]} tasks matched; only the first was flipped. Others:" >&2
  for i in $(seq 1 $((${#HITS[@]} - 1))); do
    echo "  ${HITS[$i]}" >&2
  done
fi
